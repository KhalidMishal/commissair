# .env.example
# Copy this to .env and fill in the values

# RPC URL for the Monad network (e.g. localhost for hardhat, or Monad testnet URL)
RPC_URL=http://localhost:8545

# Funded private key for the Provider Node to pay gas and receive escrow
PRIVATE_KEY=

# The deployed address of the CommissionMarket contract
CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3

# Google Gemini API Key for running generation (get it from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional provider settings
GEMINI_MODEL=gemini-1.5-flash
GEMINI_MAX_RESULT_CHARS=6000
PROVIDER_BID_MON=0.005
POLL_INTERVAL_MS=2000
